---
interface Props {
	title: string;
	badgeText?: string;
	badgeType?: 'dream' | 'dare';
	tech?: string;
	link?: string;
	linkText?: string;
	status?: string;
}

const { title, badgeText, badgeType = 'dream', tech, link, linkText = "Read more", status } = Astro.props;
---

<div class="card">
	<div>
		<div class="card-header">
			{badgeText && (
				<span class={`badge badge-${badgeType}`}>{badgeText}</span>
			)}
			{status && (
				<span class="status-pill">
					<span class="status-dot"></span>
					{status}
				</span>
			)}
			{tech && !badgeText && <span class="tech-tag">{tech}</span>}
		</div>
		<h3>{title}</h3>
		<div class="card-body">
			<slot />
		</div>
	</div>
	<div class="card-footer">
		{link ? (
			<a href={link} class="card-link">{linkText} <span>→</span></a>
		) : (
			<span></span>
		)}
		{tech && badgeText && <span class="tech-tag">{tech}</span>}
	</div>
</div>

<style>
	.card {
		background: var(--bg-surface);
		backdrop-filter: var(--glass-blur);
		border: 1px solid var(--border-color);
		border-radius: 16px;
		padding: 2.25rem;
		transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		position: relative;
		overflow: hidden;
		display: flex;
		flex-direction: column;
		justify-content: space-between;
		height: 100%;
	}

	.card::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(180deg, rgba(255,255,255,0.4) 0%, transparent 100%);
		pointer-events: none;
	}

	.card:hover {
		transform: translateY(-5px);
		border-color: var(--border-hover);
		box-shadow: 0 12px 30px rgba(15, 23, 42, 0.08);
	}

	.card-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1.25rem;
		width: 100%;
	}

	.badge {
		padding: 0.25rem 0.75rem;
		border-radius: 9999px;
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.5px;
		text-transform: uppercase;
	}

	.badge-dream {
		background: rgba(99, 102, 241, 0.08);
		color: var(--color-dream);
		border: 1px solid rgba(99, 102, 241, 0.15);
	}

	.badge-dare {
		background: rgba(13, 148, 136, 0.08);
		color: var(--color-dare);
		border: 1px solid rgba(13, 148, 136, 0.15);
	}

	.status-pill {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		font-size: 0.8rem;
		font-weight: 600;
		color: var(--text-secondary);
	}

	.status-dot {
		width: 8px;
		height: 8px;
		border-radius: 50%;
		background-color: var(--color-live);
		box-shadow: 0 0 10px rgba(16, 185, 129, 0.4);
		animation: pulse 2s infinite;
	}

	.card h3 {
		font-family: 'Outfit', sans-serif;
		font-size: 1.5rem;
		font-weight: 600;
		margin-bottom: 0.75rem;
		line-height: 1.3;
		color: var(--text-primary);
	}

	.card-body {
		color: var(--text-secondary);
		font-size: 0.95rem;
		margin-bottom: 2rem;
		font-weight: 300;
	}

	.card-footer {
		display: flex;
		align-items: center;
		justify-content: space-between;
		margin-top: auto;
		width: 100%;
	}

	.card-link {
		color: var(--color-dream);
		text-decoration: none;
		font-size: 0.95rem;
		font-weight: 600;
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		transition: gap 0.2s;
	}

	.card-link:hover {
		gap: 0.75rem;
	}

	.tech-tag {
		font-size: 0.8rem;
		color: var(--text-secondary);
		font-family: monospace;
		font-weight: 500;
	}

	@keyframes pulse {
		0% {
			transform: scale(0.95);
			box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.5);
		}
		70% {
			transform: scale(1);
			box-shadow: 0 0 0 6px rgba(16, 185, 129, 0);
		}
		100% {
			transform: scale(0.95);
			box-shadow: 0 0 0 0 rgba(16, 185, 129, 0);
		}
	}
</style>
